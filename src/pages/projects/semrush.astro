---



<Layout title="Web design by Valeri Ciutac">
    
    <ProjectHeader 
        projectName="Semrush" 
        projectRole="Designer Web Designer" 
        projectDate="05-2023" 
        projectImage="../../projects/semrush/semrush-header.webp" 
        projectDescription="Nemesysco's app is a unique blend of technology and implementation. The app design needed to be simple and present a ton of information in real time, all while focusing the viewer on the important parts of the app.The challenge was to come up with a progressive disclosure of information and emphasizing different parts of the app at varying intervals."/>
    <FullHeightImage 
        backgroundColor="#AA2C00"
        image="../../projects/semrush/semrush-full.webp" 
            />
            <Heading title="The Objective" />
    <ContentWithMedia
        imageCellWidth=4
        contentCellWidth=8
        contentImage="../../projects/semrush/chats.webp"
        contentImage2="../../projects/semrush/chats_2.webp"
        imageBgColor="#000000"
        contentTitle="Stylized chat bubbles"
        contentDescription="Used as both elements for the landing page, as well as the decorative element used in the Marketing kit." 
        />
   
    <Conclusion 
/>
        <ContactMe />
        <SeeOtherProjects 
        previousProjectLink="./openlm" 
        nextProjectLink="./automaton" 
        previousProjectTitle="OpenLM" 
        nextProjectTitle="Automaton AI"/>
    
