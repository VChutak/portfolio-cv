---
import "..//../styles/global.css";
import ProjectHeader from "..//../components/ProjectHeader.astro";
import Layout from "../../layouts/Layout.astro";
import LayoutProject from "./LayoutProject.astro";

import ContentWithMedia from "../../components/ContentWithMedia.astro";
import Conclusion from "../../components/Conclusion.astro";
import ContactMe from "../../components/ContactMe.astro";
import FullHeightImage from "../../components/FullHeightImage.astro";
import SeeOtherProjects from "../../components/SeeOtherProjects.astro";
import Heading from "../../components/Heading.astro";
---

<Layout title="Web design by Valeri Ciutac">
  <ProjectHeader
    projectName="Semrush"
    projectFocus="Marketing Optimization"
    projectDate="05-2023"
    projectImage="../../projects/semrush/semrush-header.webp"
    projectDescription=`Semrus is a leading provider of SEO and digital marketing tools, offering an advanced suite backed by an extensive index of keywords, backlinks, and advertising data. With industry-leading features, Semrus helps businesses optimize their search performance, track competitors, and refine marketing strategies with precision.

Hired to contribute to their Enterprise Competitive Intelligence product, I focus on crafting solutions that empower enterprises with deep market insights, competitive analysis, and data-driven decision-making to stay ahead in the digital landscape.`
  />
  <FullHeightImage
    backgroundColor="#AA2C00"
    image="../../projects/semrush/semrush-full.webp"
  />
  <Heading
    title="The Objective"
    subtitle="The objective was to lead the marketing materials and landing page development for the launch of Semrush Enterprise CI, a new SaaS solution. This involved creating engaging, high-impact marketing assets and designing conversion-focused landing pages to effectively communicate the product’s value and drive engagement among enterprise users."
  />
  <ContentWithMedia
    centerText={true}
    imageCellOrder={1}
    contentCellOrder={2}
    imageFirst={true}
    imageCellWidth={6}
    contentCellWidth={6}
    contentImage="../../projects/semrush/chats.webp"
    imageBgColor="#000000"
    contentTitle="Stylized chat bubbles"
    contentDescription="Having proficient knowledge of 3D apps, I modeled a pack of 3D chat bubles to be used as both elements for the landing page, as well as the decorative element used in the Marketing kit."
  />

  <ContentWithMedia
    centerText={true}
    imageCellOrder={2}
    contentCellOrder={1}
    imageFirst={false}
    imageCellWidth={8}
    contentCellWidth={4}
    contentImage="../../projects/semrush/semrush-pages.webp"
    contentTitle="Styling the pages"
    contentDescription=`The guide was designed in a chat-style format, aligning with the "21 Questions" theme. Each page presents a question-answer exchange, enhanced with custom charts and visuals to create a clear, engaging experience that seamlessly guides the reader through the eBook.`
  />

  <Conclusion />
  <ContactMe />
  <SeeOtherProjects
    previousProjectLink="./openlm"
    nextProjectLink="./bazinga"
    previousProjectTitle="OpenLM"
    nextProjectTitle="Bazinga AI"
  />
</Layout>
