    <ContentWithMedia 
    imageFirst={false}
    imageBgColor="#6212ee"
    imageCellWidth={6}
    contentCellWidth={6}
    imageCellOrder={1}
    contentCellOrder={2}
        contentImage="../../projects/writetic/writetic-featureimage.webp"
        contentTitle="The new way to write"
