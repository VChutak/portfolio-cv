    centerText={true}
        contentImage="../../projects/writetic/Writetic-templates2.gif"
        contentImage2="../../projects/writetic/Writetic-docs.gif"

        contentTitle="Optimized for fast load"
        contentDescription="I implemented Lottie animations to showcase product features in a smooth and lightweight way, replacing heavy GIFs that slowed down performance. By using Lottie’s vector-based animations, I significantly reduced file sizes, improving page speed and responsiveness. This optimization led to a faster-loading landing page and a noticeable increase in its Lighthouse performance score, enhancing both user experience and SEO rankings."
    />

    <Conclusion 
        previousProjectLink="./automaton" 
        nextProjectLink="./semrush" 
        previousProjectTitle="Automaton" 
        nextProjectTitle="Semrush"/>
