---
import "..//../styles/global.css";
import ProjectHeader from "..//../components/ProjectHeader.astro";
import Layout from "../../layouts/Layout.astro";
import ContentWithMedia from "../../components/ContentWithMedia.astro";
import Conclusion from "../../components/Conclusion.astro";
import FullHeightImage from "../../components/FullHeightImage.astro";
import SeeOtherProjects from "../../components/SeeOtherProjects.astro";
import ContactMe from "../../components/ContactMe.astro";
import Heading from "../../components/Heading.astro";
---

<Layout title="Writetic landing page design by Valeri Ciutac">
  <ProjectHeader
    projectName="Writetic"
    projectFocus="Marketing Optimization"
    projectDate="05-2023"
    projectImage="../../projects/writetic/Writetic-header.webp"
    projectDescription="Writetic is an AI-powered marketing platform designed to streamline content creation, campaign management, and team collaboration for small to medium-sized marketing teams. The platform integrates intelligent writing assistance, automated content optimization, and seamless team coordination tools to enhance productivity and creativity."
    liveLink="https://www.writetic.com/"
  />

  <FullHeightImage
    image="../../projects/writetic/writetic-full.webp"
    backgroundColor="#6229CE"
  />

  <Heading
    title="The Objective"
    subtitle="The objective was to design and develop a fast, user-friendly landing page in Figma and Webflow, ensuring an approachable and simple experience tailored for non-tech users. The design prioritized clean visuals, intuitive navigation, and clear messaging, while development focused on performance optimization for fast loading speeds, enhancing usability and engagement."
  />
  <!-- <ContentWithMedia
        imageFirst={true}
        imageCellWidth={6}
        contentCellWidth={6}
        contentImage="../../projects/writetic/Writetic-templates.gif"
        contentImage2="../../projects/writetic/Writetic-templates.gif"

        contentTitle="Show, don't tell"
        contentDescription="Animations are crucial to get your point across in a simple and effectie way. Showing the user what the app is all about in a simplified UI view is a sure way to make them understand the vlue proposition, hilenot distracting them with unnecessary UI details and small elements.">
    <h2>HFKHFKDSHFKSHFKSHFHF</h2>
    </ContentWithMedia> -->
  <ContentWithMedia
    imageFirst={false}
    imageBgColor="#6212ee"
    imageCellWidth={6}
    contentCellWidth={6}
    imageCellOrder={1}
    contentCellOrder={2}
    contentImage="../../projects/writetic/writetic-featureimage.webp"
    contentTitle="Supercharge Your Marketing with AI-Powered Collaboration"
    contentDescription="I designed a dynamic hero image that visually captures the power of an AI-driven collaborative workflow built for digital marketers. The design highlights team management, real-time collaboration, and the intuitive Article Wizard, which guides users through a step-by-step content creation process—from idea generation to outlining, defining talking points, and generating marketing visuals. The composition and visual elements ensure a clear, engaging, and user-focused representation of the platform’s capabilities."
  />

  <ContentWithMedia
    imageFirst={true}
    imageBgColor="#ffffff"
    imageCellWidth={6}
    contentCellWidth={6}
    imageCellOrder={1}
    contentCellOrder={2}
    centerText={true}
    contentImage="../../projects/writetic/Writetic-templates2.gif"
    contentImage2="../../projects/writetic/Writetic-docs.gif"
    contentTitle="Optimized for fast load"
    contentDescription="I implemented Lottie animations to showcase product features in a smooth and lightweight way, replacing heavy GIFs that slowed down performance. By using Lottie’s vector-based animations, I significantly reduced file sizes, improving page speed and responsiveness. This optimization led to a faster-loading landing page and a noticeable increase in its Lighthouse performance score, enhancing both user experience and SEO rankings."
  />

  <Conclusion
    previousProjectLink="./automaton"
    nextProjectLink="./semrush"
    previousProjectTitle="Automaton"
    nextProjectTitle="Semrush"
  />
  <ContactMe />
  <SeeOtherProjects
    previousProjectLink="./bazinga"
    nextProjectLink="./nemesysco"
    previousProjectTitle="Bazinga AI"
    nextProjectTitle="Nemesysco"
  />
</Layout>
