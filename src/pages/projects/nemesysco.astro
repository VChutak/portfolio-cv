      <style is:global>
        .custom-scrollbar::-webkit-scrollbar {
          width: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
          background: #01112b;
          border-radius: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
          background: #1a2639;
          border-radius: 8px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
          background: #2a3a52;
        }
      </style>

      <script>
        function setupPopovers() {
          document.querySelectorAll("[popover]").forEach((popover) => {
            popover.addEventListener("toggle", (e) => {
              const idNumber = popover.id.replace("popover-", "");
              const timelineMarker = document.getElementById(`btn-${idNumber}`);
              const listItem = document.getElementById(`list-item-${idNumber}`);

              if (e.newState === "open") {
                // Position over timeline marker & highlight marker
                if (timelineMarker) {
                  const markerRect = timelineMarker.getBoundingClientRect();
                  const popoverRect = popover.getBoundingClientRect();

                  const top = markerRect.top - popoverRect.height - 12;
                  const left =
                    markerRect.left +
                    markerRect.width / 2 -
                    popoverRect.width / 2;

                  const el = popover as HTMLElement;
                  el.style.top = `${top}px`;
                  el.style.left = `${left}px`;

                  timelineMarker.classList.add("scale-y-[2]", "bg-white");
                }

                // Highlight list item and scroll it into view
                if (listItem) {
                  listItem.classList.add("bg-[#152033]");
                  //  listItem.scrollIntoView({
                  // behavior: "smooth",
                  // block: "nearest",
                  // });
                }
              } else {
                // Remove highlights when the popover closes
                if (timelineMarker) {
                  timelineMarker.classList.remove("scale-y-[2]", "bg-white");
                }
                if (listItem) {
                  listItem.classList.remove(
                    "bg-[#152033]",
                    "border-l-[#f68c24]",
                  );
                }
              }
            });
          });

          // Force middle popover open on load
          const defaultPopover = document.getElementById("popover-2");
          if (defaultPopover) {
            defaultPopover.showPopover();
          }
        }

        // --- NEW ADDITION: Hide popovers on scroll ---
        function hidePopoversOnScroll() {
          document.querySelectorAll("[popover]").forEach((popover) => {
            // Check if it is currently open before trying to hide it
            // Calling hidePopover() on a closed popover throws an error
            if (popover.matches(":popover-open")) {
              popover.hidePopover();
            }
          });
        }

        // Use capture: true to catch scrolls from the window AND the inner list container
        // Use passive: true to ensure scrolling remains buttery smooth
        window.addEventListener("scroll", hidePopoversOnScroll, {
          capture: true,
          passive: true,
        });

        // Run on load
        setupPopovers();

        // Re-run if Astro uses View Transitions
        document.addEventListener("astro:page-load", setupPopovers);
      </script>
    </div>
  </Heading3>

  <Heading3
    title="4. Designing for Fault Tolerance & Graceful Recovery"
    subtitle="Instead of frustrating hard resets that destroy session data, I engineered a localized error state UI. It features an intuitive reload mechanism to gracefully recover the real-time data stream and keep the analyst's workflow intact."
  />

