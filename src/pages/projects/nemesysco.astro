            <div class="h-7 w-2 bg-[#f68c24]"></div>
            <div class="font-bold text-white text-lg w-12 text-left">0:11</div>
            <div class="text-slate-300 text-left text-[17px]">
              Subject is quite <strong class="font-bold text-white"
                >EMOTIONAL</strong
              > about this
            </div>
          </button>

          <button
            id="list-item-2"
            popovertarget="popover-2"
            class="flex items-center gap-6 w-full px-6 py-4 hover:bg-[#152033] transition-all border-l-4 border-transparent cursor-pointer"
