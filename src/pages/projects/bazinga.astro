<Layout title="Bazinga AI Web design and UI/UX design project by Valeri Ciutac">
  <!-- <ProjectScopeSummary /> -->

  <ProjectHeader
    projectName="Bazinga AI"
    projectFocus="Architecting UX. Engineering UI."
    projectStack="Figma, Blazor, Tailwind CSS"
    projectImage="../../projects/bazinga/Bazinga-header.webp"
    projectDescription=`Designed and developed the Bazinga AI platform end-to-end. I built the foundational brand identity and marketing website, then leveraged that design system to architect the core web app—transforming a complex AI assistant configuration process into an intuitive, seamless user flow.`
    liveLink="https://bazinga.ai/"
  />
  <!-- <FullHeightImage
    backgroundColor="#c9371e"
    image="../../projects/bazinga/bazinga-full-website.webp"
  /> -->
  <Heading
    title="The Problem"
    subtitle="Building a custom AI assistant is often an overwhelming, highly technical process that alienates non-developer users. Furthermore, many AI startups suffer from fragmented user journeys where the marketing site looks completely disconnected from the actual software. Bazinga AI needed a unified, intuitive experience that guided users seamlessly from discovering the product to successfully configuring and deploying their own AI agents."
  />

