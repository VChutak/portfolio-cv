      rounded-[2.5rem] rounded-tl-none md:rounded-[3rem] md:rounded-tl-none md:rounded-r-none
      bg-[#d44529] text-white overflow-visible
      
      peer-checked/blue:h-[130px] peer-checked/blue:md:h-[500px] peer-checked/blue:md:w-[28%]
      peer-checked/blue:z-10 peer-checked/blue:md:z-30
      peer-checked/blue:md:rounded-r-[4rem] peer-checked/blue:md:rounded-bl-[3rem]
