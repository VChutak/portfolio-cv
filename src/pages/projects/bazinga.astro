import ThreeCards from "../../components/ThreeCards.astro";
import ImageLightbox from "../../components/ImageLightbox.astro";
---

<Layout title="Bazinga AI Web design and UI/UX design project by Valeri Ciutac">
  <!-- <ProjectScopeSummary /> -->

  <ProjectHeader
    projectName="Bazinga AI"
    projectFocus="Architecting UX. Engineering UI."
    projectStack="Figma, Blazor, Tailwind CSS"
    projectImage="../../projects/bazinga/Bazinga-header.webp"
    projectDescription=`Designed and developed the Bazinga AI platform end-to-end. I built the foundational brand identity and marketing website, then leveraged that design system to architect the core web app—transforming a complex AI assistant configuration process into an intuitive, seamless user flow.`
    liveLink="https://bazinga.ai/"
  />
  <!-- <FullHeightImage
    backgroundColor="#c9371e"
    image="../../projects/bazinga/bazinga-full-website.webp"
  /> -->
  <Heading
    title="The Problem"
    subtitle="Building a custom AI assistant is often an overwhelming, highly technical process that alienates non-developer users. Furthermore, many AI startups suffer from fragmented user journeys where the marketing site looks completely disconnected from the actual software. Bazinga AI needed a unified, intuitive experience that guided users seamlessly from discovering the product to successfully configuring and deploying their own AI agents."
  />

  <Heading title="The Process" subtitle="" />

  <Heading3
    title="1. Visual Identity & Design System Foundation"
    subtitle="Before touching the complex application logic, I established the core brand language. I developed the logo and brand book, but rather than treating them as static graphic assets, I immediately translated them into a scalable UI design system. By defining global design tokens (typography, color variables, spacing), I ensured visual consistency across every future touchpoint."
  />

  <ContentWithMedia
    color="#1a1a1a"
    centerText={true}
    imageFirst={true}
    imageBgColor="#ffffff"
    backgroundColor="#fef3ee"
    imageCellOrder={1}
    contentCellOrder={2}
    imageCellWidth={6}
    contentCellWidth={6}
    contentImage="../../projects/bazinga/bazinga-brand0.webp"
    contentTitle="It all starts with a logo"
    contentDescription="A strong logo is simple, memorable, and versatile, ensuring it resonates with the audience across various platforms and mediums. Bazinga's logo represents a stylized chat bubble and the instantly recognizable AI magic star"
  />

  <ContentWithMedia
    centerText={true}
    imageFirst={false}
    imageCellOrder={1}
    contentCellOrder={2}
    imageCellWidth={6}
    contentCellWidth={6}
    contentTitle="Base element for the brand identity"
    contentDescription=`All graphic elements are derived from the logo’s shapes, creating a unified and recognizable design across all materials. This ensures that every visual detail—whether it’s icons, buttons, or backgrounds—feels intentional and aligned with the brand’s identity. By maintaining this consistency, the brand becomes more visually cohesive, reinforcing trust and recognition while making the user experience feel polished and seamless.`
  >
    <div slot="media-slot">
      <ImageLightbox src="../../projects/bazinga/bazinga-brand99.webp" />
    </div>
  </ContentWithMedia>

  <!-- <FullHeightImage
    backgroundColor="#fef3ee"
    text="Using the logo as the baseline, I derived a cohesive and memorable styleguide"
  > -->

<ContentWithMedia
  centerText={true}
  imageFirst={true}
  imageCellWidth={8}
  imageCellOrder={1}
  contentCellOrder={2}
  contentCellWidth={4}
  contentTitle="Color"
  contentDescription=`I carefully crafted a color palette centered around orange and blue to make the brand feel more approachable, especially for non-tech audiences. Orange conveys energy, warmth, and creativity, while blue adds a sense of trust and professionalism—striking a perfect balance between innovation and reliability.

Starting with these core colors, I systematically expanded the palette, ensuring harmony and consistency. `
>
