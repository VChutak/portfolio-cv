              >
                RGB
              </div>
              <div class="text-[10px] md:text-base font-medium">17 26 56</div>
            </div>
            <div class="md:mb-6">
              <div
                class="font-bold text-[9px] md:text-sm tracking-wider mb-0 md:mb-1 opacity-80 uppercase"
              >
                CMYK
              </div>
              <div class="text-[10px] md:text-base font-medium">70 54 0 78</div>
            </div>
            <div>
