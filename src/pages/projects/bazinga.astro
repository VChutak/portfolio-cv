        >
          <div
            class="w-full h-full rounded-[1rem] md:rounded-[2rem] overflow-hidden relative"
          >
            <!-- MOBILE IMAGE -->
            <img
              src="../../projects/bazinga/bazinga-color-blue-desktop.webp"
              alt="Blue visual component mobile"
              class="w-full h-full object-cover block md:hidden"
              onerror="this.src='https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=400&auto=format&fit=crop'"
