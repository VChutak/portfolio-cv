      />
      <input
        type="radio"
        id="bazinga-blue"
        name="bazinga-group"
        class="peer/blue hidden"
      />

      <!-- ========================================== -->
      <!-- ORANGE CARD                                -->
      <!-- ========================================== -->
      <label
        for="bazinga-orange"
        class="relative cursor-pointer transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] flex-shrink-0
