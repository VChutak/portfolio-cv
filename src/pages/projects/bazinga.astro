        >
          <h2 class="text-sm md:text-3xl font-bold leading-tight mb-0 md:mb-12">
            Bazinga<br />Orange
          </h2>

          <div
            class="flex gap-4 md:block transition-opacity duration-700 peer-checked/blue:md:opacity-0 peer-checked/blue:md:pointer-events-none text-right md:text-left"
          >
            <div class="md:mb-6">
