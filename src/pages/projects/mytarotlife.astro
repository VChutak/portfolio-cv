---
import "..//../styles/global.css";
import ProjectHeader from "..//../components/ProjectHeader.astro";
import Layout from "../../layouts/Layout.astro";
import ContentWithMedia from "../../components/ContentWithMedia.astro";
import Conclusion from "../../components/Conclusion.astro";
import SeeOtherProjects from "../../components/SeeOtherProjects.astro";
import TwoCards from "../../components/TwoCards.astro";
import Heading from "../../components/Heading.astro";
import FullWidthVideo from "../../components/FullWidthVideo.astro";
import ContactMe from "../../components/ContactMe.astro";
import ComparisonSlider from "../../components/ComparisonSlider.astro";
import FullHeightImage from "../../components/FullHeightImage.astro";
---

<Layout title="OpenLM Landing page design by Valeri Ciutac">
  <ProjectHeader
    liveLink="https://www.mytarot.life"
    projectName="My Tarot Life"
    projectFocus="3D Web Design / Web Development"
    projectDate="01-2025"
    projectImage="../../projects/mytarotlife/mtl-header.webp"
    projectDescription="My Tarot Life brings personalized card readings and other spiritual practices right at your fingertips. An optimized mobile experience and a pleasant 3D design ensure a great user experience. Your spiritual journey starts here."
  />

  <FullHeightImage
    backgroundColor="#111111"
    image="../../projects/mytarotlife/mytarotlife-full.webp"
  />
  <Heading
    title="The Objective"
    subtitle="The task was straightforward but complex - create a platform for the modern day spirituality focused business and make it look magical. The closest thing to magic on the web is 3D, so having prior experience with both 3D packages like Blender and libraries like threejs meant that I could leverage that to create a platform that would not only look beautiful, but also be incredibly intuitive and user-friendly."
  />
  <!-- <ContentWithMedia
    centerText={true}
    imageFirst={false}
    backgroundColor="#ffffff"
    imageCellWidth={6}
    imageCellOrder={2}
    contentCellWidth={6}
    contentCellOrder={1}
    contentImage="../../projects/openlm/mobile.webp"
    contentTitle="Mobile ready? Mobile First!"
    contentDescription="For this project, I prioritized responsive design from the start, ensuring a seamless experience across all screen sizes. Instead of just rearranging elements, I fine-tuned details for each viewport, adjusting spacing, typography, and interactions to maintain usability and aesthetics. I also designed custom assets specifically for mobile, optimizing visuals and layouts to enhance clarity and engagement on smaller screens. This meticulous approach ensured a polished, high-performing experience on both desktop and mobile."
  />

  <ContentWithMedia
    centerText={true}
    imageFirst={true}
    backgroundColor="#C2D0EE"
    imageCellWidth={6}
    imageCellOrder={2}
    contentCellWidth={6}
    contentCellOrder={1}
    contentImage="../../projects/openlm/openlm-wireframes1.webp"
    contentTitle="First things first"
    contentDescription="Wireframes lay the groundwork for a smooth and intuitive user experience. They help plan structure, navigation, and functionality before diving into visuals, making sure everything flows logically. By focusing on layout first, wireframes save time, prevent design mistakes, and keep the team aligned—leading to a better final product."
  />

  <ContentWithMedia
    centerText={true}
    imageFirst={true}
    backgroundColor="#C2D0EE"
    imageCellWidth={8}
    contentCellWidth={4}
    imageCellOrder={2}
    contentCellOrder={1}
    contentImage="../../projects/openlm/openlm-wireframes3.webp"
    contentTitle="First things first"
    contentDescription=``
  >
    <ul>
      <li>
        <p>
          <strong>1.</strong> Custom illustrations to enhance brand recognition utilizing
          matching color scheme and familiar imagery.
        </p>
      </li>
      <li>
        <p>
          <strong>2.</strong> A video element was replaced by before/after slider.
          This provides a simple, hands-on explanation on what is the difference.(works
          good on mobile too)
        </p>
      </li>
    </ul></ContentWithMedia
  >

  <ComparisonSlider
    lineColor="#FAC471"
    imageBefore="../../projects/openlm/before.webp"
    imageAfter="../../projects/openlm/after.webp"
    description=`A simple and fasr Before/After slider to showcase the simplicity of the Cloud implementation`
    `
  />
  <div style="padding:50.52% 0 0 0;position:relative;"><iframe src= style="position:absolute;top:0;left:0;width:100%;height:100%;" title="My Tarot Life card"></iframe></div><script src="https://player.vimeo.com/api/player.js"></script>

   -->
  <FullWidthVideo
    videoLink=`https://player.vimeo.com/video/1057814121?badge=0&autopause=0&player_id=0&app_id=58479" frameborder="0" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media`
    backgroundColor="#111111"
    color="#ffffff"
    additionalText=`For the Hero image, I designed and animated a 3D tarot card with intricate details and smooth motion, ensuring it felt immersive and interactive. I also implemented the core mechanism that allows users to submit their name and birthday, triggering the system to accept the correct card and reveal a personalized prediction. This flexible approach let me fine-tune the animations and interactions quickly, ensuring a seamless and engaging experience on the final webpage.`
    `
  />

  <Conclusion
    conclusionTitle="Conclusion"
    conclusionText1="This project was a perfect fit for me, allowing me to combine my skills in 3D design, web design, and animation to create a magical and mystical landing page."
  />
  <ContactMe />
  <SeeOtherProjects
    previousProjectLink="./nemesysco"
    nextProjectLink="./semrush"
    previousProjectTitle="Nemesysco"
    nextProjectTitle="Semrush"
  />
</Layout>
