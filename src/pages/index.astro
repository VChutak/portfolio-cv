    <div
      id="hero"
      class="lg:min-h-[35vh] min-h-[45vh] flex flex-col gap-6 justify-center items-center"
    >
      <h1
        class="lg:text-5xl text-3xl font-bold text-center sm:px-0 px-10 max-w-[23ch]"
      >
        Building the future of brand-led products.
      </h1>
      <p class="text-center lg:text-lg text-sm px-6 max-w-[70ch]">
