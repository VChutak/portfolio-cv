---
import "../styles/global.css";
const {personLink,personImage, personName, personRole, personTestimonial,cellWidth} = Astro.props
---

<div class={`flex sm:flex-row md:flex-col gap-6 col-span-${cellWidth} p-4`}>
    <div>
        <img src={personImage} alt={personImage} class="min-w-16 max-w-16 rounded-full">
    </div>
    <div class="flex flex-col gap-2">
        <div class="flex flex-col gap-0">
            <a href={personLink} target="_blank">
                <h3 class="font-bold text-2xl">{personName}</h3>
            </a>
            <p>{personRole}</p>
        </div>
        <p>{personTestimonial}</p>
    </div>
</div>