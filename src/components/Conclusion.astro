---
import "../styles/global.css";
const { conclusionText1, conclusionText2, conclusionText3, conclusionTitle } =
  Astro.props;
---

<div class="max-w-7xl mx-auto flex flex-col gap-10 px-4 py-10">
  <h3 class="text-3xl font-bold border-l-4 pl-4">{conclusionTitle}</h3>

  <ul>
    <li>
      <p class="max-w-[70ch]">{conclusionText1}</p>
    </li>
    <li>
      <p class="max-w-[70ch]">{conclusionText2}</p>
    </li>
    <li>
      <p class="max-w-[70ch]">{conclusionText3}</p>
    </li>
  </ul>
</div>
