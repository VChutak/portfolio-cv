---
import "../styles/global.css";
const {contentImage, contentTitle, contentDescription, imageCellWidth=6, contentCellWidth=6} = Astro.props
---

<div class="grid  sm:grid-cols-12 grid-cols-1 gap-10 max-w-7xl px-4 py-20 mx-auto bg-slate-100">
    <div class={`col-span-${imageCellWidth} flex flex-col jsutify-center items-center`}>
        <img src={contentImage} alt={contentImage} class="min-w-40">
    </div>
    <div class=`col-span-${contentCellWidth} flex flex-col gap-4`>
        <h3 class="text-3xl font-bold">{contentTitle}</h3>
        <p >{contentDescription}</p>
    </div>
</div>