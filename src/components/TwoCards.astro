---
import "../styles/global.css";
const {imageOne, imageTwo, cardOneTitle, cardTwoTitle, cardOneDescription, cardTwoDescription, backgroundColor} = Astro.props
---
<div class="w-full py-10" style={{backgroundColor: backgroundColor}}>
    <div class="max-w-7xl mx-auto grid sm:grid-cols-2 grid-cols-1 gap-4 px-4" >
        <div class="flex flex-col gap-10">
                <div >
                <img src={imageOne} alt={imageOne} class="rounded-lg mx-auto">
            </div>
            <div>
                <h3 class="font-bold text-3xl text-center">{cardOneTitle}</h3>
                <p class="max-w-[50ch] text-center mx-auto">{cardOneDescription}</p>
            </div>
        </div>
        <div class="flex flex-col gap-10">
            <div>
                <img src={imageTwo} alt={imageOne} class="rounded-lg mx-auto">
            </div>
            <div>
                <h3 class="font-bold text-3xl text-center">{cardTwoTitle}</h3>
                <p class="max-w-[50ch] text-center mx-auto">{cardTwoDescription}</p>
            </div>
        </div>
    </div>
</div>