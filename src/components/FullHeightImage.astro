---
import "../styles/global.css";
type Props = {
  image: string;
  backgroundColor: string;
  text?: string;
};
const { image, backgroundColor, text }: Props = Astro.props;
---

<div
  class="w-full py-10 flex flex-col gap-6"
  style={{ backgroundColor: backgroundColor }}
>
  <div class="sm:max-w-3xl max-w-lg mx-auto px-4">
    <img src={image} alt="" class="rounded-lg" />
  </div>
  <p class="mx-auto text-center">{text}</p>
</div>
