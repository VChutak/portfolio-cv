---
import astroLogo from "../assets/astro.svg";
import background from "../assets/background.svg";
import "../styles/global.css";
interface Props {
  folioImage?: string;
  backgroundColor?: string;
  backgroundColorVariation?: string;
  title?: string;
  link?: string;
  className?: string;
  projectFocus?: string;
  projectDate?: string;
  projectTags?: string[];
}
const {
  folioImage,
  backgroundColor,
  backgroundColorVariation,
  title = "default",
  link,
  className,
  projectFocus,
  projectDate,
  projectTags = ["default", "default2", "default3"],
} = Astro.props;
---

<div
  class={`group relative flex flex-col rounded-lg min-w-0 h-full transition-transform duration-300" ${className}`}
  style={{ backgroundColor }}
>
  <!-- CLICKABLE OVERLAY -->
  <a
    href={link}
    class="absolute inset-0 z-10 rounded-lg focus:outline-none focus:ring-2 focus:ring-black"
  >
    <span class="sr-only">View {title}</span>
  </a>

  <!-- HEADER -->
  <div class="flex flex-row justify-between p-4 w-full shrink-0">
    <div class="flex flex-col gap-2 text-white">
      <h3 class="text-xl font-bold">{title}</h3>
      <p class="text-pretty">{projectFocus}</p>
    </div>
    <div>
      <span
        class="lg:text-xl text-md font-bold min-w-[30%] text-right text-white"
      >
        {projectDate}
      </span>
    </div>
  </div>

  <div
    class="min-h-52 translate-y-[-100%] z-10 bg-amber-300 group:hover-translate-y-[100%] transition-transform duration-300"
  >
  </div>

  <!-- IMAGE WRAPPER (Container Query + Perf Trick) -->
  <div
    class="relative w-full flex-1 overflow-hidden [container-type:size] min-h-[250px]"
    style={`
      --img-tall: url('${title}-tall.webp');
      --img-square: url('${title}-square.webp');
      --img-wide: url('${title}-wide.webp');
      --img-ultra: url('${title}-ultrawide.webp');
    `}
  >
    <div
      class="responsive-card-bg absolute inset-0 h-full w-full bg-cover bg-center transition-all duration-300 group-hover:scale-105"
      role="img"
      aria-label={`${title} project preview`}
    >
    </div>
  </div>

  <!-- FOOTER TAGS -->
  <div
    class="flex gap-2 p-4 flex-wrap shrink-0 z-20 relative pointer-events-none rounded-b-lg"
    style={{ backgroundColor: backgroundColorVariation }}
  >
    <span class="rounded-full text-sm md:text-md py-1 px-2 text-white">
      {projectTags[0]}
    </span>
    <span class="rounded-full text-sm md:text-md py-1 px-2 text-white">
      {projectTags[1]}
    </span>
    <span class="rounded-full text-sm md:text-md py-1 px-2 text-white">
      {projectTags[2]}
    </span>
  </div>
</div>

<!-- COMPONENT STYLES -->
<style>
  /* Base state: Tall Image */
  .responsive-card-bg {
    kbackground-image: var(--img-tall);
  }

  /* Square Image */
  @container (min-aspect-ratio: 3/4) {
    .responsive-card-bg {
      background-image: var(--img-square);
    }
  }

  /* Wide Image */
  @container (min-aspect-ratio: 3/2) {
    .responsive-card-bg {
      background-image: var(--img-wide);
    }
  }

  /* Ultrawide Image */
  @container (min-aspect-ratio: 3/1) {
    .responsive-card-bg {
      background-image: var(--img-ultra);
    }
  }
</style>
