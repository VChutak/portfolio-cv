---
import astroLogo from "../assets/astro.svg";
import background from "../assets/background.svg";
import "../styles/global.css";
interface Props {
  folioImage?: string;
  backgroundColor?: string;
  backgroundColorVariation?: string;
  title?: string;
  link?: string;
  className?: string;
  projectFocus?: string;
  projectDate?: string;
  projectTags?: string[];
  projectDescription?: string;
}
const {
  folioImage,
  backgroundColor,
  backgroundColorVariation,
  title = "default",
  link,
  className,
  projectFocus,
  projectDate,
  projectTags = ["default", "default2", "default3"],
  projectDescription = `This is a test desciption of the project`,
} = Astro.props;
---

<div
  class={`group relative flex flex-col rounded-lg min-w-0 h-full overflow-hidden transition-transform duration-300 z-0 ${className}`}
  style={{ backgroundColor }}
>
  <!-- CLICKABLE OVERLAY (Highest z-index to always remain clickable) -->
  <a
    href={link}
    class="absolute inset-0 z-50 rounded-lg group-focus:ring-2 group-focus:ring-white pointer-events-noneabsolute inset-0 z-50 rounded-lg focus:ring-2 focus:ring-white"
  >
    <span class="sr-only">View {title}</span>
  </a>

  <!-- HEADER -->
  <div class="flex flex-row justify-between p-4 w-full shrink-0 z-20 relative">
    <div class="flex flex-col gap-2 text-white">
      <h3 class="text-xl font-bold">{title}</h3>
      <p class="text-pretty">{projectFocus}</p>
    </div>
    <div>
      <span
        class="lg:text-xl text-md font-bold min-w-[30%] text-right text-white"
      >
        {projectDate}
      </span>
    </div>
  </div>

  <!-- IMAGE WRAPPER -->
  <div
    class="relative w-full flex-1 overflow-hidden [container-type:size] min-h-[250px] z-10"
    style={`
      --img-tall: url('${title}-tall.webp');
      --img-square: url('${title}-square.webp');
      --img-wide: url('${title}-wide.webp');
      --img-ultra: url('${title}-ultrawide.webp');
    `}
  >
    <div
      class="responsive-card-bg absolute inset-0 h-full w-full bg-cover bg-center transition-transform duration-300 group-hover:scale-95 group-focus:scale-95"
      role="img"
      aria-label={`${title} project preview`}
    >
    </div>
  </div>

  <!-- FOOTER TAGS -->
  <div
    class="flex gap-2 p-4 flex-wrap shrink-0 z-20 relative rounded-b-lg"
    style={{ backgroundColor: backgroundColorVariation }}
  >
    <span class="rounded-full text-sm md:text-md py-1 px-2 text-white">
      {projectTags[0]}
    </span>
    <span class="rounded-full text-sm md:text-md py-1 px-2 text-white">
      {projectTags[1]}
    </span>
    <span class="rounded-full text-sm md:text-md py-1 px-2 text-white">
      {projectTags[2]}
    </span>
  </div>
</div>

<!-- COMPONENT STYLES -->
<style>
  /* Base state: Tall Image */
  .responsive-card-bg {
    background-image: var(--img-tall);
  }

  /* Square Image */
  @container (min-aspect-ratio: 3/4) {
    .responsive-card-bg {
      background-image: var(--img-square);
    }
  }

  /* Wide Image */
  @container (min-aspect-ratio: 3/2) {
    .responsive-card-bg {
      background-image: var(--img-wide);
    }
  }

  /* Ultrawide Image */
  @container (min-aspect-ratio: 3/1) {
    .responsive-card-bg {
      background-image: var(--img-ultra);
    }
  }
</style>
