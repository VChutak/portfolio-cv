---
import astroLogo from "../assets/astro.svg";
import background from "../assets/background.svg";
import "../styles/global.css";
const {
  folioImage,
  backgroundColor,
  title = "default",
  link,
  projectRole,
  projectDate,
} = Astro.props;
---

<a href={link} class="group focus:outline-none focus:ring-2 focus:ring-black">
  <div style={{ backgroundColor }} class="min-w-40 min-h-96 rounded-lg">
    <div class="flex flex-col gap-4 items-center content-center">
      <div class="flex flex-row justify-between p-4 w-full">
        <div class="flex flex-col gap-2 text-white">
          <h3 class="text-xl font-bold">{title}</h3>
          <p class="text-pretty">{projectRole}</p>
        </div>
        <div>
          <span class="text-xl font-bold text-white">{projectDate}</span>
        </div>
      </div>
      <div class="relative w-full h-full">
        <img
          src={folioImage}
          alt=`${title} project image`
          class="min-w-40 min-h-40 m-0 group-hover:scale-[1.1] transition-transform duration-150 group-focus:scale-[1.1]"
        />
      </div>
    </div>
  </div>
</a>
