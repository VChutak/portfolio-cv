---
interface Props {
  src: string;
  alt: string;
  className?: string;
}

const { src, alt, className = "" } = Astro.props;
const dialogId = `dialog-${Math.random().toString(36).substring(2, 9)}`;
---

<img
  src={src}
  alt={alt}
  id={`trigger-${dialogId}`}
  class={`rounded-xl cursor-zoom-in transition-transform hover:scale-[1.02] ${className}`}
/>

<dialog
  id={dialogId}
  class="backdrop:bg-[#00132F]/95 backdrop:backdrop-blur-sm fixed inset-0 m-auto p-0 border-none bg-transparent w-full h-full max-w-[100vw] max-h-[100vh] overflow-hidden focus:outline-none z-[999]"
>
  <div
    class="relative flex justify-center items-start w-full h-full p-4 md:p-8 overflow-y-auto overflow-x-hidden"
  >
    <button
      id={`close-${dialogId}`}
      class="fixed top-4 right-4 md:top-8 md:right-8 text-white hover:text-gray-300 p-2 cursor-pointer z-50 bg-black/40 rounded-full transition-colors hover:bg-black/60 shadow-lg backdrop-blur-md"
      aria-label="Close fullscreen"
    >
      <svg
        class="w-8 h-8"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <img
      src={src}
      alt={alt}
      class="w-full max-w-5xl h-auto object-cover rounded-lg shadow-2xl mt-14 md:mt-0"
    />
  </div>
</dialog>

<script define:vars={{ dialogId }}>
  {
    const dialog = document.getElementById(dialogId);
    const trigger = document.getElementById(`trigger-${dialogId}`);
    const closeBtn = document.getElementById(`close-${dialogId}`);

    trigger?.addEventListener("click", () => {
      dialog?.showModal();
      document.body.style.overflow = "hidden";
    });

    closeBtn?.addEventListener("click", () => {
      dialog?.close();
      document.body.style.overflow = "";
    });

    // Close modal when clicking the empty background space
    dialog?.addEventListener("click", (e) => {
      // If the user clicked directly on the image, do nothing
      if (e.target.tagName.toLowerCase() === "img") return;

      dialog.close();
      document.body.style.overflow = "";
    });
  }
</script>
