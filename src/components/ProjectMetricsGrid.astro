---
// Define your outcome types. (e.g., Conversion, Efficiency, Consistency)
const outcomes = [
  {
    metric: "+45%",
    desc: "CLICK-THROUGH RATE",
    context: "On Video Ad Campaigns (Google Flow)",
  },
  {
    metric: "+25%",
    desc: "LANDING PAGE SIGNUPS",
    context: "Vs. Previous Design",
  },
  {
    metric: "1",
    desc: "UNIFIED BRAND VOICE",
    context: "Achieved Across all Channels",
  },
];
---

<section class="results-grid bg-blue-900 text-white p-16 w-full">
  <h2 class="text-3xl font-bold text-center mb-10">
    The Impact
  </h2>
  <div class="container grid md:grid-cols-3 gap-12 text-center max-w-7xl mx-auto">
    {
      outcomes.map((outcome) => (
        <div class="outcome-block">
          <span class="text-7xl font-extrabold text-accent">
            {outcome.metric}
          </span>
          <h4 class="text-xl font-semibold mt-4">{outcome.desc}</h4>
          <p class="text-sm opacity-80 mt-2">{outcome.context}</p>
        </div>
      ))
    }
  </div>
</section>
