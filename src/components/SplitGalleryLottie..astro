---
import LottieAnimation from "astro-integration-lottie/Lottie.astro";
---

<div class="max-w-7xl block sm:hidden">
  <div class="h-full bg-[#00132F]">
    <LottieAnimation
      src="../projects/nemesysco/lottie-1.json"
      autoplay="visible"
    />
  </div>
  <div class="desc-card desc-1 p-10">
    <div class="flex items-center justify-between">
      <h6 class="text-2xl font-bold">Current Emotional Style (CES)</h6>
    </div>
    <div class="expandable-wrapper">
      <div>
        <p class="pt-4 max-w-[60ch]">
          To ground the dynamic data, this element provides a high-level summary
          of the subject's emotional baseline. I used a subtle typewriter
          animation for state changes - just enough motion to be noticed without
          stealing focus from the Diamond.
        </p>
      </div>
    </div>
  </div>

  <div class="h-full lg:min-w-[600px] min-w-[320px] bg-[#00132F] p-8">
    <LottieAnimation
      autoplay="visible"
      src="../projects/nemesysco/lottie-2.json"
    />
  </div>
  <div class="desc-card desc-2 p-10">
    <div class="flex items-center justify-between">
      <h6 class="text-2xl font-bold">Emotional Diamond</h6>
    </div>
    <div class="expandable-wrapper">
      <div>
        <p class="pt-4 max-w-[60ch]">
          I redesigned the ED to anchor the screen's visual hierarchy. Its
          contrast dynamically spikes when an emotion peaks, effortlessly
          drawing the eye. Always in motion, it acts as the living core of the
          interface, turning invisible vocal data into a real-time emotional
          map.
        </p>
      </div>
    </div>
  </div>

  <div class="h-full bg-[#00132F]">
    <LottieAnimation
      class=`mt-[-80px] mb-[-20p]`
      autoplay="visible"
      src="../projects/nemesysco/lottie-3.json"
    />
  </div>
  <div class="desc-card desc-3 p-10">
    <div class="flex items-center justify-between">
      <h6 class="text-2xl font-bold">Emotional Snapshots</h6>
    </div>
    <div class="expandable-wrapper">
      <div>
        <p class="pt-4 max-w-[60ch]">
          To map historical data, these timeline markers track past emotional
          states. Their visual weight sits exactly between the Diamond and the
          CES, making past emotional spikes easy to scan without distracting
          from the real-time Diamond.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- ----------------------------- -->

<div class="md:grid grid-cols-2 max-w-7xl hidden md:block">
  <input
    type="radio"
    name="gallery-state"
    id="sec-1"
    class="hidden-radio"
    checked
  />
  <input type="radio" name="gallery-state" id="sec-2" class="hidden-radio" />
  <input type="radio" name="gallery-state" id="sec-3" class="hidden-radio" />

  <div class="img-wrapper img-wrap-1 h-full bg-[#00132F]">
    <LottieAnimation
      id="lottie-1"
      src="../projects/nemesysco/lottie-1.json"
      autoplay="visible"
    />
  </div>
  <label for="sec-1" class="desc-card desc-1 p-10">
    <div class="flex items-center justify-between">
      <h6 class="text-2xl font-bold">Current Emotional Style (CES)</h6>
      <svg
        class="chevron-icon w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
    <div class="expandable-wrapper">
      <div class="expandable-inner">
        <p class="pt-4 max-w-[60ch]">
          To ground the dynamic data, this element provides a high-level summary
          of the subject's emotional baseline. I used a subtle typewriter
          animation for state changes - just enough motion to be noticed without
          stealing focus from the Diamond.
        </p>
      </div>
    </div>
  </label>

  <div
    class="img-wrapper img-wrap-2 h-full lg:min-w-[600px] min-w-[320px] bg-[#00132F] p-8"
  >
    <LottieAnimation
      autoplay={false}
      id="lottie-2"
      src="../projects/nemesysco/lottie-2.json"
    />
  </div>
  <label for="sec-2" class="desc-card desc-2 p-10">
    <div class="flex items-center justify-between">
      <h6 class="text-2xl font-bold">Emotional Diamond</h6>
      <svg
        class="chevron-icon w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
    <div class="expandable-wrapper">
      <div class="expandable-inner">
        <p class="pt-4 max-w-[60ch]">
          I redesigned the ED to anchor the screen's visual hierarchy. Its
          contrast dynamically spikes when an emotion peaks, effortlessly
          drawing the eye. Always in motion, it acts as the living core of the
          interface, turning invisible vocal data into a real-time emotional
          map.
        </p>
      </div>
    </div>
  </label>

  <div class="img-wrapper img-wrap-3 h-full bg-[#00132F]">
    <LottieAnimation
      class=`mt-[-80px] mb-[-20p]`
      autoplay={false}
      id="lottie-3"
      src="../projects/nemesysco/lottie-3.json"
    />
  </div>
  <label for="sec-3" class="desc-card desc-3 p-10">
    <div class="flex items-center justify-between">
      <h6 class="text-2xl font-bold">Emotional Snapshots</h6>
      <svg
        class="chevron-icon w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 9l-7 7-7-7"></path>
      </svg>
    </div>
    <div class="expandable-wrapper">
      <div class="expandable-inner">
        <p class="pt-4 max-w-[60ch]">
          To map historical data, these timeline markers track past emotional
          states. Their visual weight sits exactly between the Diamond and the
          CES, making past emotional spikes easy to scan without distracting
          from the real-time Diamond.
        </p>
      </div>
    </div>
  </label>
</div>
<script>
  function setupPlayback() {
    const api = window.astroLottie;

    if (!api) return;

    const mapping = {
      "sec-1": "lottie-1",
      "sec-2": "lottie-2",
      "sec-3": "lottie-3",
    };

    function pauseAll() {
      Object.values(mapping).forEach((id) => {
        const animation = api.getAnimation(id);

        if (animation?.player) {
          animation.player.pause();
        }
      });
    }

    function handlePlayback() {
      const checked = document.querySelector(
        'input[name="gallery-state"]:checked',
      );

      if (!checked) return;

      pauseAll();

      const activeAnimation = api.getAnimation(mapping[checked.id]);

      if (activeAnimation?.player) {
        activeAnimation.player.play();
      }
    }

    document
      .querySelectorAll('input[name="gallery-state"]')
      .forEach((radio) => {
        radio.addEventListener("change", handlePlayback);
      });

    handlePlayback();
  }

  document.addEventListener("astro-lottie-loaded", setupPlayback, {
    once: true,
  });
</script>
