---
import "../styles/global.css";

type Props = {
  imageBefore: string;
  imageAfter: string;
  // imageBeforeMobile: string;
  // imageAfterMobile: string;
  lineColor?: string;
  description?: string;
};

const {
  imageBefore,
  imageAfter,
  // imageBeforeMobile,
  // imageAfterMobile,
  lineColor,
  description,
}: Props = Astro.props;

const lineColorString = `bg-[${lineColor}]`;
console.log(lineColorString);
---

<div class=`max-w-7xl px-10 flex flex-col gap-6 py-10 px-6 mx-auto `>
  <div class=`container mx-auto border-2 border-[#FAC471] rounded-lg w-full`>
    <div class="image-container">
      <img
        class="image-before slider-image sm:visible hidden"
        src={imageBefore}
        alt="before image"
      />

      <img
        class="image-after slider-image sm:visible hidden"
        src={imageAfter}
        alt="after image"
      />
    </div>

    <input
      type="range"
      min="0"
      max="100"
      value="50"
      aria-label="Percentage of before photo shown"
      class="slider absolute inset-0 cursor-grab h-full w-full"
    />
    <div class=`slider-line bg-[#FAC471]` aria-hidden="true"></div>
    <div class="slider-button" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="30"
        height="30"
        fill="currentColor"
        viewBox="0 0 256 256"
      >
        <rect width="256" height="256" fill="none"></rect>
        <line
          x1="128"
          y1="40"
          x2="128"
          y2="216"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></line>
        <line
          x1="96"
          y1="128"
          x2="16"
          y2="128"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></line>
        <polyline
          points="48 160 16 128 48 96"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></polyline>
        <line
          x1="160"
          y1="128"
          x2="240"
          y2="128"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></line>
        <polyline
          points="208 96 240 128 208 160"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></polyline>
      </svg>
    </div>
  </div>
  <div>
    <p>{description}</p>
  </div>
</div>

<style>
  img {
    display: block;
    max-width: 100%;
  }

  /* main {
    display: grid;
    place-items: center;
    min-height: 100vh;
  } */

  .container {
    display: grid;
    place-content: center;
    position: relative;
    overflow: hidden;

    --position: 50%;
  }

  .image-container {
    /* max-width: 800px; */
    max-height: 90vh;
    /* aspect-ratio: 2/1.5; */
  }

  .slider-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left;
  }

  .image-before {
    position: absolute;
    inset: 0;
    width: var(--position);
    /* filter: grayscale(100%); */
  }

  .slider {
    opacity: 0;
    /* for Firefox */
  }

  .slider:focus-visible ~ .slider-button {
    outline: 2px solid black;
    outline-offset: 4px;
  }

  .slider-line {
    position: absolute;
    inset: 0;
    width: 0.15rem;
    height: 100%;

    /* z-index: 10; */
    left: var(--position);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .slider-button {
    position: absolute;
    background-color: #fac471;
    color: black;
    padding: 0.5rem;
    border-radius: 100vw;
    display: grid;
    place-items: center;
    top: 50%;
    left: var(--position);
    transform: translate(-50%, -50%);
    pointer-events: none;
    /* z-index: 100; */
    box-shadow: 1px 1px 1px hsl(0, 50%, 2%, 0.5);
  }
</style>

<script>
  const container = document.querySelector(".container");
  document.querySelector(".slider").addEventListener("input", (e) => {
    container.style.setProperty("--position", `${e.target.value}%`);
  });
</script>
