---
import "../styles/global.css";

type Props = {
  imageBefore: string;
  imageAfter: string;
  lineColor?: string;
  iconColor?: string;
  description?: string;
  startPosition?: number | string;
};

const {
  imageBefore,
  imageAfter,
  lineColor = "#442580",
  iconColor = "#000000",
  description,
  startPosition = 50,
} = Astro.props;
---

<div class="max-w-7xl flex flex-col gap-6 py-10 mx-auto">
  <div
    class="container border-2 rounded-lg w-full min-h-75"
    style={`--position: ${startPosition}%;`}
  >
    <div class="image-container">
      <img
        class="image-before slider-image sm:visible hidden"
        src={imageBefore}
        alt="before image"
        decoding="async"
      />

      <img
        class="image-after slider-image sm:visible hidden"
        src={imageAfter}
        alt="after image"
        decoding="async"
      />
    </div>

    <input
      type="range"
      min="0"
      max="100"
      value={startPosition}
      aria-label="Percentage of before photo shown"
      class="slider absolute inset-0 cursor-grab h-full w-full"
    />

    <div class="slider-line" aria-hidden="true"></div>
    <div class="slider-button" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="30"
        height="30"
        viewBox="0 0 256 256"
      >
        <rect width="256" height="256" fill="none"></rect>
        <line
          x1="128"
          y1="40"
          x2="128"
          y2="216"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></line>
        <line
          x1="96"
          y1="128"
          x2="16"
          y2="128"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></line>
        <polyline
          points="48 160 16 128 48 96"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></polyline>
        <line
          x1="160"
          y1="128"
          x2="240"
          y2="128"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></line>
        <polyline
          points="208 96 240 128 208 160"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="16"></polyline>
      </svg>
    </div>
  </div>
  <div>
    <p>{description}</p>
  </div>
</div>

<style define:vars={{ dynamicColor: lineColor, dynamicIconColor: iconColor }}>
  img {
    display: block;
    max-width: 100%;
  }

  .container {
    display: grid;
    place-content: center;
    position: relative;
    overflow: hidden;
    border-color: var(--dynamicColor);
  }

  .image-container {
    max-height: 90vh;
  }

  .slider-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left;
  }

  .image-before {
    position: absolute;
    inset: 0;
    /* OPTIMIZATION 1: Use clip-path instead of width */
    width: 100%;
    clip-path: polygon(0 0, var(--position) 0, var(--position) 100%, 0 100%);
    will-change: clip-path; /* Tells the browser to prep the GPU for this */
  }

  .slider {
    opacity: 0;
  }

  .slider:focus-visible ~ .slider-button {
    outline: 2px solid white;
    outline-offset: 4px;
  }

  .slider-line {
    position: absolute;
    inset: 0;
    width: 0.15rem;
    height: 100%;
    background-color: var(--dynamicColor);
    left: var(--position);
    transform: translateX(-50%);
    pointer-events: none;
    will-change: left;
  }

  .slider-button {
    position: absolute;
    background-color: var(--dynamicColor);
    color: var(--dynamicIconColor);
    padding: 0.5rem;
    border-radius: 100vw;
    display: grid;
    place-items: center;
    top: 50%;
    left: var(--position);
    transform: translate(-50%, -50%);
    pointer-events: none;
    box-shadow: 1px 1px 1px hsl(0, 50%, 2%, 0.5);
    will-change: left;
  }
</style>

<script>
  const sliders = document.querySelectorAll(".container");

  sliders.forEach((container) => {
    const sliderInput = container.querySelector(".slider");
    let isUpdating = false;

    if (sliderInput) {
      sliderInput.addEventListener("input", (e) => {
        // OPTIMIZATION 2: requestAnimationFrame
        if (!isUpdating) {
          window.requestAnimationFrame(() => {
            const target = e.target as HTMLInputElement;
            (container as HTMLElement).style.setProperty(
              "--position",
              `${target.value}%`,
            );
            isUpdating = false;
          });
          isUpdating = true;
        }
      });
    }
  });
</script>
