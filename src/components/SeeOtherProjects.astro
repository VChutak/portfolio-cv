---
import "../styles/global.css";
const {previousProjectLink, nextProjectLink,previousProjectTitle, nextProjectTitle} = Astro.props
---

<div class="max-w-7xl mx-auto flex flex-col gap-10 px-4 py-10">
    <div class="flex flex-col gap-4">
        <h4 class="text-2xl text-center">See some of my other Projects</h4> 
        <div class="flex flex-row gap-4 justify-between">
            <div class="flex flex-col justify-center items-center py-10 px-20 border-1 rounded-lg group">
                <a href={previousProjectLink}class="group-hover:translate-x-[-10px] text-xl transition duration-100">← {previousProjectTitle}</a> 
            </div>
            <div class="flex flex-col justify-center items-center py-10 px-20 border-1 rounded-lg group">
                <a href={nextProjectLink} class="group-hover:translate-x-[10px] text-xl transition duration-100">{nextProjectTitle} →</a>
            </div>
        </div>
    </div>
</div>